# DEGIRO Portfolio Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Price Data Provider
# =============================================================================
# Default: yahoo (free, no API key required)
PRICE_DATA_PROVIDER=yahoo

# =============================================================================
# Server Configuration
# =============================================================================
# DEGIRO_PORTFOLIO_HOST=0.0.0.0
# DEGIRO_PORTFOLIO_PORT=8000

# =============================================================================
# Database Location
# =============================================================================
# DEGIRO_PORTFOLIO_DB=/path/to/degiro_portfolio.db

# =============================================================================
# Data Fetching Periods
# =============================================================================
# INITIAL_FETCH_PERIOD=max
# INDEX_FETCH_PERIOD=5y
# UPDATE_FETCH_PERIOD=7d
